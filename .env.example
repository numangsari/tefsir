# ── Veritabanı (PostgreSQL — Neon önerilir) ───────────────────────────────────
# Neon: Settings → Connection string → Pooled connection
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/tefsir?sslmode=require&pgbouncer=true"
# Neon: Settings → Connection string → Direct connection (migration için)
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/tefsir?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Üretmek için: openssl rand -base64 32
NEXTAUTH_SECRET="buraya_guclu_bir_secret_yazin"
NEXTAUTH_URL="https://tefsir.net"

# ── E-posta (Resend) ──────────────────────────────────────────────────────────
# resend.com → API Keys → Create API Key
# Domain doğrulaması: resend.com → Domains → tefsir.net ekle
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ── AI modernizasyon (opsiyonel — scripts/modernize-tafsirs.ts için) ──────────
# Desteklenen provider'lar: "gemini" veya "ollama" (başka provider desteklenmez)

# Gemini (bulut) — https://aistudio.google.com/ → API key
# Kullanım: GEMINI_API_KEY=... npm run modernize -- --surah=1 --provider=gemini
# GEMINI_API_KEY="AIza..."

# Ollama (lokal)
# MODERNIZE_PROVIDER=ollama
# OLLAMA_HOST="http://127.0.0.1:11434"
# MODERNIZE_PAUSE_MS=4000
# MODERNIZE_BATCH_SIZE=15
# MODERNIZE_BATCH_PAUSE_MS=90000
# MODERNIZE_CHUNK_PAUSE_MS=2000
# OLLAMA_NUM_THREAD=3
# OLLAMA_NUM_CTX=8192
